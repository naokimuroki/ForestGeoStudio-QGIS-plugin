           </layout>
          </widget>
         </item>
         <!-- ラスタ（タイル）レイヤのスタイル設定 -->
         <item>
          <widget class="QWidget" name="widgetRaster">
           <layout class="QHBoxLayout" name="layoutRaster">
            <item><widget class="QLabel" name="lblRasterOpacity"><property name="text"><string>不透明度:</string></property></widget></item>
            <item>
             <widget class="QDoubleSpinBox" name="spinRasterOpacity">
              <property name="minimum"><double>0.000000000000000</double></property>
              <property name="maximum"><double>1.000000000000000</double></property>
              <property name="singleStep"><double>0.100000000000000</double></property>
              <property name="value"><double>1.000000000000000</double></property>
              <property name="maximumWidth"><number>80</number></property>
             </widget>
            </item>
            <item><widget class="QLabel" name="lblRasterZoom"><property name="text"><string>表示ズーム:</string></property></widget></item>
            <item>
             <widget class="QDoubleSpinBox" name="spinRasterMinZoom">
              <property name="minimum"><double>0.000000000000000</double></property>
              <property name="maximum"><double>24.000000000000000</double></property>
              <property name="value"><double>0.000000000000000</double></property>
              <property name="maximumWidth"><number>70</number></property>
             </widget>
            </item>
            <item><widget class="QLabel" name="lblRasterZoomTo"><property name="text"><string>～</string></property></widget></item>
            <item>
             <widget class="QDoubleSpinBox" name="spinRasterMaxZoom">
              <property name="minimum"><double>0.000000000000000</double></property>
              <property name="maximum"><double>24.000000000000000</double></property>
              <property name="value"><double>24.000000000000000</double></property>
              <property name="maximumWidth"><number>70</number></property>
             </widget>
            </item>
            <item>
             <spacer name="spacerRaster">
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
             </spacer>
            </item>
           </layout>
          </widget>
         </item>
         <!-- 属性値色分けルール（VectorTile / fgb 共通） -->
         <item>
          <widget class="QWidget" name="widgetVtColorRules">
           <layout class="QVBoxLayout" name="layoutVtColorRules">
            <item>
             <layout class="QHBoxLayout" name="layoutVtColorRulesHeader">
              <item>
               <widget class="QCheckBox" name="chkVtColorRule">
                <property name="text"><string>属性値で色分け</string></property>
               </widget>
              </item>
              <item>
               <widget class="QLabel" name="lblVtColorRuleField">
                <property name="text"><string>属性フィールド名:</string></property>
               </widget>
              </item>
              <item>
               <widget class="QLineEdit" name="txtVtColorRuleField">
                <property name="placeholderText"><string>例: name, label …</string></property>
                <property name="maximumWidth"><number>160</number></property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btnVtAddRule">
                <property name="text"><string>行追加</string></property>
                <property name="maximumWidth"><number>70</number></property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btnVtRemoveRule">
                <property name="text"><string>行削除</string></property>
                <property name="maximumWidth"><number>70</number></property>
               </widget>
              </item>
              <item>
               <spacer>
                <property name="orientation"><enum>Qt::Horizontal</enum></property>
                <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
               </spacer>
              </item>
             </layout>
            </item>
            <item>
             <widget class="QTableWidget" name="tblVtColorRules">
              <property name="minimumSize">
               <size>
                <width>1040</width>
                <height>130</height>
               </size>
              </property>
              <property name="maximumHeight"><number>130</number></property>
              <attribute name="horizontalHeaderMinimumSectionSize">
               <number>34</number>
              </attribute>
              <attribute name="horizontalHeaderDefaultSectionSize">
               <number>140</number>
              </attribute>
              <attribute name="verticalHeaderDefaultSectionSize">
               <number>30</number>
              </attribute>
              <column><property name="text"><string>文字列で分類</string></property></column>
              <column><property name="text"><string>数値で分類（下限値）</string></property></column>
              <column><property name="text"><string>数値で分類（上限値）</string></property></column>
              <column><property name="text"><string>配色</string></property></column>
              <column><property name="text"><string>不透明度（空欄=既定）</string></property></column>
              <column><property name="text"><string>枠幅／ライン幅（空欄=既定）</string></property></column>
             </widget>
            </item>
           </layout>
          </widget>
         </item>

         <item>
          <layout class="QHBoxLayout" name="layoutApplyStyle">
           <item>
            <widget class="QPushButton" name="btnApplyStyle">
             <property name="minimumSize">
              <size>
               <width>200</width>
               <height>0</height>
              </size>
             </property>
             <property name="text">
              <string>このスタイルをレイヤに適用</string>
             </property>
            </widget>
           </item>
           <item>
            <spacer name="spacerApplyStyle">
             <property name="orientation">
              <enum>Qt::Horizontal</enum>
             </property>
             <property name="sizeHint" stdset="0">
              <size>
               <width>40</width>
               <height>20</height>
              </size>
             </property>
            </spacer>
           </item>
           <item>
            <widget class="QPushButton" name="btnLoadStyle">
             <property name="text">
              <string>スタイル設定をファイルから読込</string>
             </property>
             <property name="toolTip">
              <string>別の地図作成時に保存したスタイル設定を読み込み、このレイヤの初期値としてプリセットします。読込後も各項目は手修正できます。</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="btnSaveStyle">
             <property name="text">
              <string>このスタイル設定をファイルで保存</string>
             </property>
             <property name="toolTip">
              <string>現在UIに入力されているこのレイヤのスタイル設定をファイルに保存します。別の地図作成時に使い回せます。</string>
             </property>
            </widget>
           </item>
          </layout>
         </item>
        </layout>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupOption">
     <property name="title">
      <string>表示オプション</string>
     </property>
     <layout class="QVBoxLayout" name="layoutOption">
      <item>
       <layout class="QHBoxLayout" name="layoutOptionRow1">
        <item>
         <widget class="QCheckBox" name="chkLayerPanel">
          <property name="text">
           <string>レイヤパネル</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkZoom">
          <property name="text">
           <string>ズームコントロール</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkScale">
          <property name="text">
           <string>スケールバー</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkCoord">
          <property name="text">
           <string>マウス座標</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkAddrSearch">
          <property name="text">
           <string>住所検索</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkGps">
          <property name="text">
           <string>現在地取得</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkShareLink">
          <property name="text">
           <string>地図共有リンク</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkPopup">
          <property name="text">
           <string>属性ポップアップ</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <spacer name="spacerOptionRow1">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>20</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="layoutOptionRow2">
        <item>
         <widget class="QCheckBox" name="chkFeatureSearch">
          <property name="text">
           <string>属性検索バー</string>
          </property>
          <property name="toolTip">
           <string>ベクタレイヤの属性値で地物を検索し、該当範囲へ画面遷移できる検索バーを画面下部に常設します。</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkAreaCalc">
          <property name="text">
           <string>面積計算</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkDistCalc">
          <property name="text">
           <string>距離計算</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkDraw">
          <property name="text">
           <string>作図機能</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkDrawExport">
          <property name="text">
           <string>作図データ出力</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkGeoJsonImport">
          <property name="text">
           <string>外部データ入力</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkExternalTile">
          <property name="text">
           <string>外部タイル入力</string>
          </property>
          <property name="toolTip">
           <string>閲覧者がXYZ形式のラスタタイル（{z}/{x}/{y}）URLを入力して地図に重ねられるボタンを追加します。表示ズーム範囲も指定できます。</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkTerrain3D">
          <property name="text">
           <string>3D表示</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkSplitView">
          <property name="text">
           <string>スプリットビュー</string>
          </property>
          <property name="toolTip">
           <string>現在のレイヤ表示で固定した左ビューと、レイヤパネルで調整できる右ビューを並べて比較します。中心位置・ズームは連動し、境界はドラッグで左右に動かせます。</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <spacer name="spacerOptionRow2">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>20</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="layoutOptionRow3">
        <item>
         <widget class="QCheckBox" name="chkStats">
          <property name="text">
           <string>属性値集計・分析※OPT2</string>
          </property>
          <property name="toolTip">
           <string>選択フィーチャーの属性を集計し、統計表・グラフを表示します。※オプションパックをお持ちの方のみ使用できます。</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
         <item>
         <widget class="QCheckBox" name="chkPrint">
          <property name="text">
           <string>地図印刷※OPT2</string>
          </property>
          <property name="toolTip">
           <string>現在の地図表示を所定のA4横テンプレートにレイアウトして印刷します。※オプションパックをお持ちの方のみ使用できます。</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkZoning">
          <property name="text"><string>ゾーニング※OPT2</string></property>
          <property name="toolTip"><string>標高タイル、林野庁オープンデータ等を用いて「もりぞん」ゾーニングをシミュレートできます。※オプションパックをお持ちの方のみ使用できます。</string></property>
          <property name="checked"><bool>false</bool></property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chkRoadSim">
          <property name="text"><string>路網設計シミュレート※OPT2</string></property>
          <property name="toolTip"><string>標高タイルを用いて勾配制約付きの林道・林業専用道・森林作業道の線形を自動探索し、縦断図検証・バッファ単木集計・GeoJSON出力を行います。※オプションパックをお持ちの方のみ使用できます。</string></property>
          <property name="checked"><bool>false</bool></property>
         </widget>
        </item>
        <item>
          <widget class="QCheckBox" name="chkRoute">
          <property name="text"><string>ルート検索※OPT2</string></property>
          <property name="toolTip"><string>国土数値情報・道路データを用いて、起点・終点から速度優先と距離優先の2経路を検索します。通行不能ポリゴンがあれば回避します。※オプションパックをお持ちの方のみ使用できます。</string></property>
          <property name="checked"><bool>false</bool></property>
          </widget>
        </item>
        <item>
          <widget class="QCheckBox" name="chkCableSim">
          <property name="text"><string>架線設計シミュレート※OPT2</string></property>
          <property name="toolTip"><string>標高タイルを用いて主索（架線）の通り・クリアランス・主索安全係数（規定2.7）を概算し、必要支柱高や中間サポートの要否、横取り範囲内の単木集計・採算（材積×単価）を表示します。エンドレスタイラー／タワーヤーダに対応。※オプションパックをお持ちの方のみ使用できます。</string></property>
          <property name="checked"><bool>false</bool></property>
          </widget>
        </item>
        <item>
         <spacer name="spacerOptionRow3">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>20</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </item>
     </layout>
    </widget>
