  <property name="styleSheet">
   <string notr="true">
/* =========================================================
   ForestGeo Studio Theme
   palette:
     deep   #43A28C   mid    #6ABC6E   light  #BEDFC2
     cream  #FFFDF6   yellow #FFFCDA
     text   #1e3a2f   sub    #4a7c65

   ※ QCheckBox / QSpinBox / QDoubleSpinBox は
     ネイティブのチェックマーク・▲▼を残すため
     indicator・arrow部分はカスタムしません。
   ========================================================= */

/* ---- Font (全体に Noto Sans JP を適用) ---- */
* {
    font-family: "Noto Sans JP", "Yu Gothic UI", "Meiryo", sans-serif;
}

/* ---- Base ---- */
QDialog {
    background-color: #FFFDF6;
    color: #1e3a2f;
}
QWidget {
    color: #1e3a2f;
}
QLabel {
    background: transparent;
    color: #1e3a2f;
}

/* ---- Inputs ---- */
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background-color: #FFFFFF;
    color: #1e3a2f;
    border: 1px solid #BEDFC2;
    border-radius: 4px;
    padding: 3px 6px;
    selection-background-color: #6ABC6E;
    selection-color: #FFFDF6;
}
QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border: 1px solid #43A28C;
}
QLineEdit:disabled, QSpinBox:disabled, QDoubleSpinBox:disabled, QComboBox:disabled {
    background-color: #FFFCDA;
    color: #4a7c65;
}

/* ComboBox dropdown menu */
QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    color: #1e3a2f;
    selection-background-color: #6ABC6E;
    selection-color: #FFFDF6;
    border: 1px solid #BEDFC2;
    outline: 0;
}

/* ---- Buttons (default = mid) ---- */
QPushButton {
    background-color: #6ABC6E;
    color: #FFFDF6;
    border: none;
    border-radius: 4px;
    padding: 6px 14px;
    font-weight: 600;
}
QPushButton:hover {
    background-color: #43A28C;
}
QPushButton:pressed {
    background-color: #1e3a2f;
}
QPushButton:disabled {
    background-color: #BEDFC2;
    color: #4a7c65;
}

/* Color picker buttons + browse + row add/remove (light, subtle) */
QPushButton#btnPointColor,
QPushButton#btnPointStroke,
QPushButton#btnLineColor,
QPushButton#btnFillColor,
QPushButton#btnOutlineColor,
QPushButton#btnLabelColor,
QPushButton#btnLabelHaloColor,
QPushButton#btnVtFillColor,
QPushButton#btnVtOutlineColor,
QPushButton#btnVtLineColor,
QPushButton#btnVtPointColor,
QPushButton#btnVtPointStroke,
QPushButton#btnVtLabelColor,
QPushButton#btnVtLabelHaloColor,
QPushButton#btnBrowse,
QPushButton#btnVtAddRule,
QPushButton#btnVtRemoveRule {
    background-color: #BEDFC2;
    color: #1e3a2f;
    padding: 4px 10px;
    font-weight: normal;
}
QPushButton#btnPointColor:hover,
QPushButton#btnPointStroke:hover,
QPushButton#btnLineColor:hover,
QPushButton#btnFillColor:hover,
QPushButton#btnOutlineColor:hover,
QPushButton#btnLabelColor:hover,
QPushButton#btnLabelHaloColor:hover,
QPushButton#btnVtFillColor:hover,
QPushButton#btnVtOutlineColor:hover,
QPushButton#btnVtLineColor:hover,
QPushButton#btnVtPointColor:hover,
QPushButton#btnVtPointStroke:hover,
QPushButton#btnVtLabelColor:hover,
QPushButton#btnVtLabelHaloColor:hover,
QPushButton#btnBrowse:hover,
QPushButton#btnVtAddRule:hover,
QPushButton#btnVtRemoveRule:hover {
    background-color: #6ABC6E;
    color: #FFFDF6;
}

/* Apply style button (secondary mid - already default) */
QPushButton#btnApplyStyle,
QPushButton#btnSaveStyle,
QPushButton#btnLoadStyle {
    padding: 7px 18px;
}

/* Primary action button (HTML output) */
QPushButton#btnRun {
    background-color: #43A28C;
    color: #FFFDF6;
    font-size: 14px;
    font-weight: bold;
    padding: 10px 24px;
    border-radius: 6px;
}
QPushButton#btnRun:hover {
    background-color: #1e3a2f;
}

/* ---- GroupBox (outer = yellow tint) ---- */
QGroupBox {
    background-color: #FFFCDA;
    border: 1px solid #BEDFC2;
    border-radius: 6px;
    margin-top: 14px;
    padding: 14px 10px 10px 10px;
    font-weight: bold;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 0 8px;
    color: #43A28C;
    background-color: #FFFDF6;
}

/* Nested GroupBox (inner = cream) */
QGroupBox#groupLayerStyle {
    background-color: #FFFDF6;
    border: 1px solid #BEDFC2;
}
QGroupBox#groupLayerStyle::title {
    color: #4a7c65;
    background-color: #FFFCDA;
}

/* ---- TableWidget ---- */
QTableWidget {
    background-color: #FFFFFF;
    color: #1e3a2f;
    border: 1px solid #BEDFC2;
    border-radius: 4px;
    alternate-background-color: #FFFCDA;
    gridline-color: #BEDFC2;
    outline: 0;
}
QTableWidget::item {
    padding: 4px;
}
QTableWidget::item:selected {
    background-color: #6ABC6E;
    color: #FFFDF6;
}
QTableWidget::item:hover {
    background-color: #BEDFC2;
}

/* Table headers */
QHeaderView::section {
    background-color: #43A28C;
    color: #FFFDF6;
    padding: 5px 8px;
    border: none;
    border-right: 1px solid #6ABC6E;
    font-weight: bold;
}
QTableCornerButton::section {
    background-color: #43A28C;
    border: none;
}

/* ---- CheckBox (背景と区別できるよう白いピル状ボックス / ネイティブのチェックマーク保持) ---- */
QCheckBox {
    color: #1e3a2f;
    spacing: 8px;
    background-color: #FFFFFF;
    border: 1px solid #BEDFC2;
    border-radius: 4px;
    padding: 4px 10px;
}
QCheckBox:hover {
    border: 1px solid #6ABC6E;
}
QCheckBox:checked {
    background-color: #BEDFC2;
    border-color: #43A28C;
}
QCheckBox:disabled {
    background-color: #FFFCDA;
    color: #4a7c65;
    border-color: #BEDFC2;
}

/* ---- ScrollArea (背景透過、枠なし) ---- */
QScrollArea {
    background: transparent;
    border: none;
}
QScrollArea > QWidget > QWidget {
    background: transparent;
}

/* ---- ScrollBar ---- */
QScrollBar:vertical {
    background: #FFFDF6;
    width: 10px;
    margin: 0;
    border: none;
}
QScrollBar::handle:vertical {
    background: #BEDFC2;
    border-radius: 5px;
    min-height: 24px;
}
QScrollBar::handle:vertical:hover {
    background: #6ABC6E;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
    background: none;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}
QScrollBar:horizontal {
    background: #FFFDF6;
    height: 10px;
    margin: 0;
    border: none;
}
QScrollBar::handle:horizontal {
    background: #BEDFC2;
    border-radius: 5px;
    min-width: 24px;
}
QScrollBar::handle:horizontal:hover {
    background: #6ABC6E;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
    background: none;
}
   </string>
  </property>
