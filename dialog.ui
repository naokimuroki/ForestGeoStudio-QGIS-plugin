            </item>

            <!-- Row 5: point style (shown for Point) -->
            <item>
             <widget class="QWidget" name="widgetVtPoint">
              <layout class="QHBoxLayout" name="layoutVtPoint">
               <item><widget class="QLabel" name="lblVtPointColor"><property name="text"><string>ポイント色:</string></property></widget></item>
               <item><widget class="QLineEdit" name="txtVtPointColor"><property name="text"><string>#e63946</string></property><property name="maximumWidth"><number>90</number></property></widget></item>
               <item><widget class="QPushButton" name="btnVtPointColor"><property name="text"><string>選択</string></property><property name="maximumWidth"><number>52</number></property></widget></item>
               <item><widget class="QLabel" name="lblVtPointRadius"><property name="text"><string>半径:</string></property></widget></item>
               <item>
                <widget class="QSpinBox" name="spinVtPointRadius">
                 <property name="minimum"><number>2</number></property>
                 <property name="maximum"><number>30</number></property>
                 <property name="value"><number>6</number></property>
                 <property name="maximumWidth"><number>70</number></property>
                </widget>
               </item>
               <item><widget class="QLabel" name="lblVtPointStroke"><property name="text"><string>枠線色:</string></property></widget></item>
               <item><widget class="QLineEdit" name="txtVtPointStroke"><property name="text"><string>#ffffff</string></property><property name="maximumWidth"><number>90</number></property></widget></item>
               <item><widget class="QPushButton" name="btnVtPointStroke"><property name="text"><string>選択</string></property><property name="maximumWidth"><number>52</number></property></widget></item>
               <item>
                <spacer name="spacerVtPoint">
                 <property name="orientation"><enum>Qt::Horizontal</enum></property>
                 <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
                </spacer>
               </item>
              </layout>
             </widget>
            </item>

            <!-- Row 5a-2: 単木SVGアイコン（プション treesvg.js） -->
            <item>
             <widget class="QWidget" name="widgetVtTreeSvg">
              <layout class="QVBoxLayout" name="layoutVtTreeSvg">
               <property name="leftMargin"><number>0</number></property>
               <property name="topMargin"><number>0</number></property>
               <property name="rightMargin"><number>0</number></property>
               <property name="bottomMargin"><number>0</number></property>
               <item>
                <widget class="QCheckBox" name="chkVtTreeSvg">
                 <property name="text"><string>単木ポイントデータに樹木アイコンを適用</string></property>
                 <property name="toolTip"><string>チェックすると、3Dビュー時に樹木アイコンでポイントを表示チェックしない場合は上段で設定したポイントの色・半径設定が優先。</string></property>
                </widget>
               </item>
               <item>
                <widget class="QLabel" name="lblVtTreeSvgNote">
                 <property name="text"><string>※ 樹木アイコン表示はOPT2をお持ちの方のみ使用できます。</string></property>
                 <property name="wordWrap"><bool>true</bool></property>
                 <property name="styleSheet"><string>color:#888;font-size:11px;</string></property>
                </widget>
               </item>
              </layout>
             </widget>
            </item>

            <!-- Row 5b: data-driven color rules -->

            <!-- Row 6: label -->
            <item>
             <widget class="QWidget" name="widgetVtLabel">
